generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AccessModel {
  FREE
  ONE_TIME_CREDIT
  SUBSCRIPTION
  METERED
}

enum PriceKind {
  ONE_TIME
  SUBSCRIPTION
  CREDIT_PACK
}

enum CreditTier {
  FTR
  SDP_SRP
  COMPETENCY
  GENERAL
}

enum EntitlementStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum ServiceRequestType {
  CONSULTATION
  DELIVERY
  SUPPORT
}

enum ServiceRequestStatus {
  SUBMITTED
  TRIAGED
  PROPOSAL_SENT
  SCHEDULED
  IN_PROGRESS
  BLOCKED
  DELIVERED
  CLOSED
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String?        @unique
  emailVerified  DateTime?
  image          String?
  role           Role           @default(USER)
  stripeCustomerId String?      @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  accounts       Account[]
  sessions       Session[]
  userAuth       UserAuth?
  entitlements   Entitlement[]
  creditBalances CreditBalance[]
  auditLogs      AuditLog[]
  leadLogs       LeadLog[]
  architectureReviewJobs ArchitectureReviewJob[]
  landingZoneReadinessSubmissions LandingZoneReadinessSubmission[]
  cloudCostLeakFinderSubmissions CloudCostLeakFinderSubmission[]
  checkoutFulfillments CheckoutFulfillment[]
  usageEvents    UsageEvent[]
  serviceRequests ServiceRequest[]
}

model Product {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  description  String
  active       Boolean       @default(true)
  accessModel  AccessModel
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  prices       Price[]
  entitlements Entitlement[]
  creditBalances CreditBalance[]
  checkoutFulfillments CheckoutFulfillment[]
  usageEvents  UsageEvent[]
}

model Price {
  id            String    @id @default(cuid())
  productId     String
  stripePriceId String    @unique
  kind          PriceKind
  currency      String    @default("usd")
  amount        Int
  creditsGranted Int      @default(1)
  creditTier    CreditTier @default(GENERAL)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Entitlement {
  id                   String            @id @default(cuid())
  userId               String
  productId            String
  remainingUses        Int               @default(0)
  validUntil           DateTime?
  stripeSubscriptionId String?           @unique
  status               EntitlementStatus @default(ACTIVE)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  product              Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model CreditBalance {
  id            String            @id @default(cuid())
  userId        String
  productId     String
  tier          CreditTier
  remainingUses Int               @default(0)
  status        EntitlementStatus @default(ACTIVE)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, tier])
  @@index([userId, productId])
}

model CheckoutFulfillment {
  id                      String   @id @default(cuid())
  stripeCheckoutSessionId String   @unique
  stripeEventId           String?
  userId                  String
  productId               String
  createdAt               DateTime @default(now())

  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product                 Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
}

model UsageEvent {
  id                  String   @id @default(cuid())
  userId              String
  productId           String
  quantity            Int      @default(1)
  stripeMeterEventId  String?
  createdAt           DateTime @default(now())

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId, productId])
}

model ServiceRequest {
  id             String               @id @default(cuid())
  userId         String
  trackingCode   String               @unique
  type           ServiceRequestType
  title          String
  summary        String
  preferredStart DateTime?
  budgetRange    String?
  status         ServiceRequestStatus @default(SUBMITTED)
  latestNote     String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  metadataJson Json?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
}

model LeadLog {
  id                   String   @id @default(cuid())
  userId               String?
  userEmail            String
  userName             String?
  architectureProvider String
  authProvider         String?
  overallScore         Int
  analysisConfidence   String?
  quoteTier            String?
  emailDeliveryMode    String?
  leadStage            String   @default("New Review")
  leadScore            Int?
  ctaClicks            Int      @default(0)
  lastCtaClickedAt     DateTime?
  topIssues            String
  inputParagraph       String?
  reportJson           Json?
  utmSource            String?
  utmMedium            String?
  utmCampaign          String?
  landingPage          String?
  referrer             String?
  deviceClass          String?
  clientTimingJson     Json?
  workdriveDiagramFileId String?
  workdriveReportFileId  String?
  workdriveUploadStatus  String?
  emailSentAt          DateTime?
  followUpStatusJson   Json?
  zohoSyncNeedsUpdate  Boolean  @default(true)
  syncedToZohoAt       DateTime?
  zohoRecordId         String?
  zohoSyncError        String?
  createdAt            DateTime @default(now())

  user                 User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  architectureReviewJobs ArchitectureReviewJob[]
  architectureReviewEmailOutboxes ArchitectureReviewEmailOutbox[]

  @@index([createdAt])
  @@index([userEmail])
  @@index([syncedToZohoAt])
}

model ArchitectureReviewJob {
  id                   String   @id @default(cuid())
  userId               String?
  userEmail            String
  status               String   @default("queued")
  currentPhase         String?
  progressPct          Int      @default(0)
  etaSeconds           Int?
  attemptCount         Int      @default(0)
  errorMessage         String?
  diagramFileName      String
  diagramMimeType      String
  diagramBytes         Bytes
  metadataJson         Json
  submissionContextJson Json?
  clientTimingJson     Json?
  phaseTimingsJson     Json?
  reportJson           Json?
  overallScore         Int?
  analysisConfidence   String?
  quoteTier            String?
  deliveryMode         String?
  fallbackReason       String?
  fallbackMailtoUrl    String?
  fallbackEmlToken     String?
  leadLogId            String?
  startedAt            DateTime?
  completedAt          DateTime?
  lastHeartbeatAt      DateTime?
  nextRetryAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  leadLog              LeadLog? @relation(fields: [leadLogId], references: [id], onDelete: SetNull)
  emailOutboxes        ArchitectureReviewEmailOutbox[]

  @@index([status])
  @@index([createdAt])
  @@index([userEmail])
  @@index([userId])
  @@index([leadLogId])
}

model ArchitectureReviewEmailOutbox {
  id           String   @id @default(cuid())
  jobId         String
  leadLogId     String?
  toEmail       String
  subject       String
  textBody      String   @db.Text
  htmlBody      String?  @db.Text
  status        String   @default("pending")
  attemptCount  Int      @default(0)
  provider      String?
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  job           ArchitectureReviewJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  leadLog       LeadLog? @relation(fields: [leadLogId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([leadLogId])
  @@index([status])
}

model LandingZoneReadinessSubmission {
  id                   String   @id @default(cuid())
  userId               String?
  email                String
  fullName             String
  companyName          String
  roleTitle            String
  website              String?
  primaryCloud         String
  secondaryCloud       String?
  answersJson          Json
  scoreOverall         Int
  scoreByCategoryJson  Json
  maturityBand         String
  findingsJson         Json
  quoteJson            Json
  freeTextChallenge    String?
  crmSyncStatus        String?
  emailDeliveryStatus  String?
  zohoRecordId         String?
  zohoSyncError        String?
  source               String   @default("landing-zone-readiness-checker")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([email])
  @@index([crmSyncStatus])
}

model CloudCostLeakFinderSubmission {
  id                           String   @id @default(cuid())
  userId                       String?
  email                        String
  fullName                     String
  companyName                  String
  roleTitle                    String
  website                      String?
  primaryCloud                 String
  secondaryCloud               String?
  narrativeInput               String
  billingSummaryInput          String?
  extractedSignalsJson         Json
  adaptiveAnswersJson          Json
  wasteRiskScore               Int
  finopsMaturityScore          Int
  savingsConfidenceScore       Int
  implementationComplexityScore Int
  roiPlausibilityScore         Int
  confidenceScore              Int
  likelyWasteCategoriesJson    Json
  savingsEstimateJson          Json
  findingsJson                 Json
  actionsJson                  Json
  quoteJson                    Json
  crmSyncStatus                String?
  emailDeliveryStatus          String?
  zohoRecordId                 String?
  zohoSyncError                String?
  source                       String   @default("cloud-cost-leak-finder")
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  user                         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([email])
  @@index([crmSyncStatus])
}

model UserAuth {
  id                  String   @id @default(cuid())
  userId              String   @unique
  passwordHash        String
  passwordUpdatedAt   DateTime @default(now())
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lockedUntil])
  @@index([resetTokenExpiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
