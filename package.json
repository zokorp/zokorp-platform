{
  "name": "zokorp-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --reporter=list",
    "test:e2e:local": "JOURNEY_MARKETING_BASE_URL=http://127.0.0.1:3000 JOURNEY_APP_BASE_URL=http://127.0.0.1:3000 E2E_MUTATION_MODE=readonly playwright test --reporter=list",
    "test:e2e:preview": "E2E_MUTATION_MODE=readonly playwright test --reporter=list",
    "test:e2e:production": "E2E_MUTATION_MODE=readonly playwright test --reporter=list",
    "smoke:preview": "node scripts/production_smoke_check.mjs",
    "smoke:production": "node scripts/production_smoke_check.mjs",
    "ops:audit:production": "node scripts/production_provider_audit.mjs",
    "ops:proof:production": "node scripts/production_operational_proof.mjs",
    "uptime:check": "node scripts/uptime_monitor.mjs",
    "soft-launch:audit:production": "node scripts/soft_launch_audit_production.mjs",
    "journey:setup:production": "node scripts/provision_browser_audit_user.mjs --environment=production",
    "journey:audit:preview": "node scripts/browser_customer_journey_audit.mjs",
    "journey:audit:production": "node scripts/browser_customer_journey_audit.mjs",
    "journey:walkthrough": "node scripts/full_gui_walkthrough.mjs",
    "journey:walkthrough:low-risk": "JOURNEY_MUTATION_MODE=low-risk node scripts/full_gui_walkthrough.mjs",
    "journey:walkthrough:preview": "node scripts/full_gui_walkthrough.mjs",
    "journey:walkthrough:production": "node scripts/full_gui_walkthrough.mjs",
    "journey:a11y": "node scripts/accessibility_audit.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.81",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.48.0",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "next": "^16.2.3",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.6.205",
    "prisma": "^6.19.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
