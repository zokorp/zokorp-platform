# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_long_random_secret
ARCHIVE_ENCRYPTION_SECRET=replace_with_long_random_archive_secret
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zokorp_platform?schema=public

# Password login
AUTH_PASSWORD_ENABLED=true

# Password reset + fallback SMTP email delivery
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=example_user
EMAIL_SERVER_PASSWORD=example_password
EMAIL_FROM=hello@zokorp.com

# Resend (preferred email provider for architecture review results)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Roles
ZOKORP_ADMIN_EMAILS=you@zokorp.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_FTR_SINGLE=price_...
STRIPE_PRICE_ID_SDP_SRP_SINGLE=price_...
STRIPE_PRICE_ID_COMPETENCY_REVIEW=price_...
STRIPE_PRICE_ID_PLATFORM_MONTHLY=price_...
STRIPE_PRICE_ID_PLATFORM_ANNUAL=price_...

# Upload settings
UPLOAD_MAX_MB=10
ARCHITECTURE_REVIEW_UPLOAD_MAX_MB=6

# Architecture review fallback draft signing
ARCH_REVIEW_EML_SECRET=
ARCH_REVIEW_CTA_SECRET=
ARCH_REVIEW_DAILY_LIMIT=24
ARCH_REVIEW_WORKER_SECRET=
ARCH_REVIEW_BOOK_CALL_URL=http://localhost:3000/services#service-request
ARCH_REVIEW_REMEDIATION_PLAN_URL=http://localhost:3000/services#service-request
ARCH_REVIEW_FOLLOWUP_SECRET=
CRON_SECRET=
CALENDLY_SYNC_SECRET=
